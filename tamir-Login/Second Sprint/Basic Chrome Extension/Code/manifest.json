{
  "manifest_version": 2,
  "name": "Password Manager",
  "version": "1.0",
  "description": "Logs messages to the console",
  "permissions": [ "activeTab", "storage" ],
  "background": {
    "scripts": [ "background.js" ],
    "persistent": false
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "browser_action": {
    "default_icon": "logo.png"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content_script.js" ]
    }
  ]
}
